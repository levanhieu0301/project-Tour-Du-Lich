extends ../layouts/default.pug

block title 
    title Thông tin website
block main
    h2.box-title Thông tin website
    //- Section-8
    .section-8
        form#setting-website-info-form
            .inner-group 
                label(class="inner-label" for="create-web") Tạo website
                input(type="text" id="create-web" name="create-web"  value="28.TRAVEL")
            .inner-group 
                label(class="inner-label" for="phone") Số điện thoại
                input(type="number" id="phone" name="phone"   value="01234568")
            .inner-group 
                label(class="inner-label" for="email") Email
                input(type="text" id="email" name="email" value="contact@.travel.com")
            .inner-group 
                label(class="inner-label" for="addres") Địa chỉ
                input(type="text" id="addres" name="addres" value="Số 123, đường ABC")
            .inner-group.inner-two-col
                label(class="inner-label" for="logo") Logo
                div(class="inner-upload-image")
                    input(type="file" id="logo" accept="image/*" filepond-image)
            .inner-group.inner-two-col
                label(class="inner-label" for="favicon") Favicon
                div(class="inner-upload-image")
                    input(type="file" id="favicon" accept="image/*" filepond-image)
            .inner-group.inner-button
                button Cập nhật
        .inner-back 
            a(href="#") Quay lại danh sách
    //-End Section-8
