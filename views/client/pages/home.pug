extends ../layouts/default.pug 
include ../mixins/product-item.pug


block main 
  // Section 1
  .section-1
    .container
      .inner-wrap
        h1.inner-title(
          data-aos-duration="3000" 
          data-aos="fade-up"
          )
          | Du lịch Châu Á - Khám phá Mỹ, Úc, Âu
          br
          | Đi nơi đâu bạn muốn
        p.inner-desc(
          data-aos-duration="3000" 
          data-aos="fade-up"
          )
          | Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          |   eiusmod tempor incididunt ut labore et dolore magna aliqua
        form.inner-form(action="")
          .inner-box.inner-address
            .inner-input-group
              img.inner-icon(
                alt="" 
                src="/assets/css/images/Address.png"
                )
              input.inner-input(
                placeholder="Bạn muốn đi đâu?" 
                type="text"
                )
              i.fa-solid.fa-angle-down.inner-down
            .inner-suggest
              .inner-suggest-title
                i.fa-solid.fa-location-dot
                | Địa Điểm Hot
              .inner-suggest-list
                .inner-item
                  .inner-item-image
                    img(
                      alt="" 
                      src="/assets/css/images/3-1.jpg"
                      )
                  .inner-item-content
                    .inner-item-title Nhật Bản
                    .inner-item-desc 50 tours
                .inner-item
                  .inner-item-image
                    img(
                      alt="" 
                      src="/assets/css/images/3-2.jpg"
                      )
                  .inner-item-content
                    .inner-item-title Phú Quốc
                    .inner-item-desc 50 tours
                .inner-item
                  .inner-item-image
                    img(
                      alt="" 
                      src="/assets/css/images/3-3.jpg"
                      )
                  .inner-item-content
                    .inner-item-title Singapore
                    .inner-item-desc 50 tours
          .inner-box.inner-user
            .inner-input-group
              img.inner-icon(
                alt="" 
                src="/assets/css/images/user.png"
                )
              input.inner-input(
                readonly="" 
                placeholder="Số lượng" 
                type="text"
                )
              i.fa-solid.fa-angle-down.inner-down
            .inner-quantity
              .inner-item
                .inner-label Người lớn
                .inner-count
                  span.inner-down -
                  span.inner-number 1
                  span.inner-up +
              .inner-item
                .inner-label Trẻ em
                .inner-count
                  span.inner-down -
                  span.inner-number 0
                  span.inner-up +
              .inner-item
                .inner-label Em bé
                .inner-count
                  span.inner-down -
                  span.inner-number 0
                  span.inner-up +
          .inner-box.inner-calendar
            .inner-input-group
              img.inner-icon(
                alt="" 
                src="/assets/css/images/time.png"
                )
              input.inner-input(
                placeholder="Lịch khởi hành" 
                type="text"
                )
              i.fa-solid.fa-angle-down.inner-down
          button.inner-button
            i.fa-solid.fa-magnifying-glass
            | Tìm Kiếm
